{
  "manifest_version": 3,
  "name": "Meta Lineup Filter",
  "version": "1.2.11",
  "description": "Narrow down GeoGuessr countries by the visual clues you're seeing - side of driving, stop sign wording, road line and chevron colors, special alphabet letters and more.",
  "action": {
    "default_title": "Open Meta Lineup Filter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["sidePanel"],
  "host_permissions": ["https://ofiiluzxhnyzkbjlqfgk.supabase.co/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
